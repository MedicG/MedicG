{
    "$schema":  "https://openapi.vercel.sh/vercel.json",
    "version":  2,
    "rewrites":  [
                     {
                         "source":  "/api/:path*",
                         "destination":  "/api/index"
                     }
                 ],
    "headers":  [
                    {
                        "source":  "/",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/index.html",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(.*)",
                        "headers":  [
                                        {
                                            "key":  "X-Content-Type-Options",
                                            "value":  "nosniff"
                                        },
                                        {
                                            "key":  "Referrer-Policy",
                                            "value":  "no-referrer"
                                        },
                                        {
                                            "key":  "X-Frame-Options",
                                            "value":  "DENY"
                                        }
                                    ]
                    }
                ]
}
