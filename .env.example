# Copia estos valores en Vercel > Project Settings > Environment Variables.
# No subas valores reales con claves o passwords a GitHub.

# Base de datos PostgreSQL/Neon. Usa uno de estos nombres.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Administrador inicial del sistema.
ADMIN_EMAIL=admin@medicg.com
ADMIN_PASSWORD=CambiaEstaClaveSegura123

# URLs publicas.
PUBLIC_API_URL=https://TU-PROYECTO.vercel.app
PUBLIC_APP_URL=https://TU-USUARIO.github.io/TU-REPO
ALLOWED_ORIGINS=https://TU-USUARIO.github.io

# Correo para verificacion de usuarios registrados usando SMTP.
# Ejemplo puerto normal: 587 con SMTP_TLS=true y SMTP_SSL=false.
# Ejemplo puerto SSL: 465 con SMTP_TLS=false y SMTP_SSL=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tudominio.com
SMTP_FROM_NAME=Medic G
SMTP_TLS=true
SMTP_SSL=false

# Opcion alternativa recomendada en Vercel: Resend.
# Si usas Resend, puedes dejar SMTP_HOST vacio.
RESEND_API_KEY=
RESEND_FROM=Medic G <no-reply@tudominio.com>
RESEND_ENDPOINT=https://api.resend.com/emails

# Solo para pruebas locales: muestra el link de verificacion en la respuesta JSON.
# En produccion debe quedar false.
SHOW_VERIFICATION_LINK=false